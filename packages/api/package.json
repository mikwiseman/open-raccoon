{
  "name": "@wai-agents/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/s3-request-presigner": "^3.1001.0",
    "@hono/node-server": "^1.14.3",
    "@wai-agents/shared": "workspace:*",
    "argon2": "^0.44.0",
    "bullmq": "^5.51.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.7.11",
    "ioredis": "^5.6.1",
    "jose": "^6.0.11",
    "openai": "^5.4.0",
    "pg": "^8.16.0",
    "postgres": "^3.4.7",
    "socket.io": "^4.8.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.1",
    "msw": "^2.8.4",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
